# Kopieer naar .env en vul in. .env staat in .gitignore — commit hem nooit.

# SMTP2GO (Sending → SMTP Users)
SMTP_HOST=mail-eu.smtp2go.com
SMTP_PORT=465
SMTP_USER=arjankapteijn.nl
SMTP_PASS=vul-hier-je-wachtwoord-in

# Waar de terminal-mailtjes heen gaan / vandaan lijken te komen.
# Het from-domein moet als sender domain geverifieerd zijn in SMTP2GO.
MAIL_TO=info@arjankapteijn.nl
MAIL_FROM=Station AK-01 <noreply@arjankapteijn.nl>

# SolarEdge Monitoring — voedt het accupercentage in de menubalk.
# Zonder deze twee valt de site terug op een statisch percentage.
SOLAREDGE_API_KEY=vul-hier-je-api-key-in
SOLAREDGE_SITE_ID=vul-hier-je-site-id-in

# Scheepslogboek via Signal (signal-cli-rest-api). Elk getypt commando
# wordt als Signal-bericht gepusht. Zonder deze twee staat het logboek uit.
SIGNAL_API_URL=https://signal.voorbeeld.nl
SIGNAL_NUMBER=+31600000000
# Ontvanger(s), komma-gescheiden. Leeg = note-to-self naar SIGNAL_NUMBER.
SIGNAL_RECIPIENTS=+31600000001

# Grove herkomst ("Amsterdam, NL") bij elke logregel, via een gratis key-loze
# geo-API (server/geo.js). Standaard ip-api.com; meestal niet nodig in te
# vullen. Zet leeg (GEO_API_URL=) om de locatie-lookup helemaal uit te zetten.
GEO_API_URL=http://ip-api.com/json
